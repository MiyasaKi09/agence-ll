---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLocale, useTranslations, alternatePath, isLocaleReady } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  /** chemin absolu vers une image OG (1200×630) dans /public, ex. "/og/accueil.jpg" */
  ogImage?: string;
  /** variables CSS de teinte appliquées à toute la page (fiche projet) */
  theme?: string;
}
const {
  title = 'Agence L&L — Architecture',
  description = "Agence d'architecture entre Paris et la Normandie. Rénovation énergétique, logement, équipements publics. Matériaux biosourcés, attention au vivant.",
  ogImage = '/og-default.jpg',
  theme,
} = Astro.props;

const locale = getLocale(Astro.url);
const t = useTranslations(locale);
const ogLocale = locale === 'en' ? 'en_GB' : 'fr_FR';

const base = Astro.site ?? Astro.url;
const canonical = new URL(Astro.url.pathname, base).toString();
const ogUrl = new URL(ogImage, base).toString();
const hrefFr = new URL(alternatePath(Astro.url.pathname, 'fr'), base).toString();
const hrefEn = new URL(alternatePath(Astro.url.pathname, 'en'), base).toString();
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#EEEAE1" />

    <!-- Alternances de langue (FR/EN) — EN annoncé seulement quand les pages existent -->
    <link rel="alternate" hreflang="fr" href={hrefFr} />
    {isLocaleReady('en') && <link rel="alternate" hreflang="en" href={hrefEn} />}
    <link rel="alternate" hreflang="x-default" href={hrefFr} />

    <!-- Open Graph / réseaux -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="Agence L&L" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogUrl} />

    <!-- Favicon : remplace par ton monogramme exporté -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Polices -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Hanken+Grotesk:wght@300..800&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
    />
  </head>
  <body style={theme} class={theme ? 'is-themed' : undefined}>
    <a href="#contenu" class="skip-link">{t('skip')}</a>

    <Header />
    <main id="contenu">
      <slot />
    </main>
    <Footer />
  </body>
</html>

