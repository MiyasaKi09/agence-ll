---
// Axonométrie dessinée d'un bâtiment, GÉNÉRÉE par projet (reprise du design
// Claude « Site Agence L&L »). On passe l'identifiant du projet : le massing
// vient de projets-data.ts et la teinte de sa catégorie. On peut aussi forcer
// un `spec` (massing) et/ou une `teinte`.
import { axoSvg } from '../lib/axono';
import { PROJETS_META, type AxoBox } from '../lib/projets-data';
import { teinteFor, teinteVars, type Teinte } from '../lib/teinte';

interface Props {
  /** identifiant du projet (collection) — détermine massing + teinte */
  id?: string;
  /** massing explicite (prioritaire sur `id`) */
  spec?: AxoBox[];
  /** teinte explicite (sinon déduite de l'id) */
  teinte?: Teinte;
  class?: string;
}
const { id, spec, teinte, class: cls } = Astro.props;

const FALLBACK: AxoBox[] = [{ x: 0, y: 0, w: 3, d: 4, h: 4, roof: 2 }];
const boxes = spec ?? (id ? PROJETS_META[id]?.axo : undefined) ?? FALLBACK;
const t = teinte ?? (id ? teinteFor(id) : undefined);
const style = t ? teinteVars(t) : undefined;
const svg = axoSvg(boxes);
---
<div class={`axono ${cls ?? ''}`} style={style} aria-hidden="true" set:html={svg}></div>

<style>
  .axono {
    aspect-ratio: 3 / 2;
    display: grid;
    place-items: center;
    padding: 0.6rem 0;
    --ph1: #E7DECF;
    --ph2: #D8CCB7;
    --surface: #F4EFE6;
    transition: transform 0.4s var(--ease);
  }
</style>
