---
import { getLocale, useTranslations, localizePath } from '../i18n/utils';

const path = Astro.url.pathname;
const locale = getLocale(Astro.url);
const t = useTranslations(locale);

const nav = [
  { href: '/projets', key: 'nav.projets' as const },
  { href: '/journal', key: 'nav.journal' as const },
  { href: '/agence', key: 'nav.agence' as const },
  { href: '/contact', key: 'nav.contact' as const },
];
const isActive = (href: string) => {
  const localized = localizePath(href, locale);
  return path === localized || path.startsWith(localized + '/');
};
---
<header class="site-header">
  <div class="container bar">
    <a href={localizePath('/', locale)} class="brand plain" aria-label="Agence L&L">
      Agence&nbsp;L<span class="amp">&amp;</span>L
    </a>

    <nav class="desk-nav" aria-label="Navigation principale">
      <ul>
        {nav.map((item) => (
          <li>
            <a
              href={localizePath(item.href, locale)}
              class="nav-link plain"
              aria-current={isActive(item.href) ? 'page' : undefined}
            >{t(item.key)}</a>
          </li>
        ))}
      </ul>
    </nav>

    <a href={localizePath('/contact', locale)} class="rdv plain">Prendre rendez-vous</a>

    <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav">Menu</button>
  </div>

  <nav class="mobile-nav" id="mobile-nav" aria-label="Navigation principale (mobile)" hidden>
    {nav.map((item) => (
      <a
        href={localizePath(item.href, locale)}
        class="mnav-link plain"
        aria-current={isActive(item.href) ? 'page' : undefined}
      >{t(item.key)}</a>
    ))}
    <a href={localizePath('/contact', locale)} class="mnav-rdv plain">Prendre rendez-vous</a>
  </nav>
</header>

<script>
  function initHeaderMenu() {
    const btn = document.querySelector<HTMLButtonElement>('.menu-toggle');
    const panel = document.getElementById('mobile-nav');
    if (!btn || !panel || btn.dataset.wired === '1') return;
    btn.dataset.wired = '1';
    btn.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!open));
      panel.hidden = open;
    });
  }
  document.addEventListener('astro:page-load', initHeaderMenu);
</script>

<style>
  /* « Liquid glass » léger : verre dépoli translucide qui suit la teinte de la page,
     forte saturation/flou, fin liseré de lumière en haut, ombre douce dessous. */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--paper) 60%, transparent);
    backdrop-filter: blur(20px) saturate(185%);
    -webkit-backdrop-filter: blur(20px) saturate(185%);
    border-bottom: 1px solid color-mix(in srgb, var(--ink) 8%, transparent);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.55),
      0 8px 24px -12px rgba(26, 23, 20, 0.12);
    transition: background-color 0.45s var(--ease);
  }
  /* Repli si color-mix indisponible (vieux navigateurs) */
  @supports not (background: color-mix(in srgb, white, black)) {
    .site-header { background: rgba(246, 242, 235, 0.72); }
  }
  .bar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-m);
    min-height: 4.75rem;
  }

  /* Mot-marque — Cormorant Garamond 25px / 600 (& non italique) */
  .brand {
    justify-self: start;
    font-family: var(--font-display);
    font-size: 25px;
    font-weight: 600;
    letter-spacing: 0.25px;
    color: var(--ink);
    white-space: nowrap;
  }

  /* Navigation centrale — Hanken Grotesk 14px MAJ (comme le design) */
  .desk-nav { justify-self: center; }
  .desk-nav ul {
    display: flex;
    gap: clamp(1.4rem, 3vw, 2.5rem);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .nav-link {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.84px;
    text-transform: uppercase;
    color: var(--ink);
    padding-block: 0.3rem;
    border-bottom: 1.5px solid transparent;
    white-space: nowrap;
    transition: border-color 0.2s var(--ease), color 0.2s var(--ease);
  }
  .nav-link:hover { color: var(--terracotta); }
  .nav-link[aria-current='page'] { border-color: var(--terracotta); }

  /* Bouton « Prendre rendez-vous » — Hanken Grotesk 11px MAJ, contour ink */
  .rdv {
    justify-self: end;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.88px;
    text-transform: uppercase;
    color: var(--ink);
    border: 1px solid var(--ink);
    padding: 10px 16px;
    white-space: nowrap;
    transition: background-color 0.2s var(--ease), color 0.2s var(--ease);
  }
  .rdv:hover { background: var(--ink); color: var(--paper); }

  /* Bouton « Menu » (mobile uniquement) */
  .menu-toggle {
    display: none;
    justify-self: end;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    border: 1px solid var(--ink);
    padding: 8px 12px;
    background: none;
  }

  /* Panneau de navigation mobile (replié par défaut) */
  .mobile-nav {
    display: none;
    flex-direction: column;
    gap: 2px;
    padding: 4px clamp(1.25rem, 5vw, 4rem) 18px;
  }
  .mobile-nav[hidden] { display: none; }
  .mnav-link, .mnav-rdv {
    font-family: var(--font-body);
    font-size: 14px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink);
    padding: 11px 0;
    border-top: 1px solid color-mix(in srgb, var(--ink) 10%, transparent);
  }
  .mnav-link[aria-current='page'] { color: var(--terracotta); }
  .mnav-rdv {
    margin-top: 10px;
    text-align: center;
    border: 1px solid var(--ink);
    padding: 11px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
  }

  /* Responsive : on replie la nav desktop, on montre le bouton Menu */
  @media (max-width: 60rem) {
    .bar { grid-template-columns: 1fr auto; }
    .desk-nav, .rdv { display: none; }
    .menu-toggle { display: inline-block; }
    .mobile-nav:not([hidden]) { display: flex; }
  }
  @media (min-width: 60.0625rem) {
    .mobile-nav { display: none !important; }
  }
</style>
