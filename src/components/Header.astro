---
import Monogram from './Monogram.astro';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);

const nav = [
  { href: '/agence', label: 'Agence' },
  { href: '/projets', label: 'Projets' },
  { href: '/contact', label: 'Contact' },
];
---
<header class="site-header">
  <div class="container bar">
    <a href="/" class="brand plain" aria-label="Agence L&L — accueil">
      <Monogram variant="mark" size={46} />
      <span class="wordmark">Agence&nbsp;L&amp;L</span>
    </a>
    <nav aria-label="Navigation principale">
      <ul>
        {nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="nav-link plain"
              aria-current={isActive(item.href) ? 'page' : undefined}
            >{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--paper) 88%, transparent);
    backdrop-filter: saturate(1.2) blur(6px);
    border-bottom: var(--rule);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-m);
    min-height: 4.5rem;
  }
  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.7rem;
  }
  .brand :global(svg) { color: var(--ink); }
  .wordmark {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  nav ul {
    display: flex;
    gap: clamp(1rem, 3vw, 2.4rem);
    list-style: none;
    padding: 0;
  }
  .nav-link {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding-block: 0.3rem;
    border-bottom: 1.5px solid transparent;
    transition: border-color 0.2s var(--ease), color 0.2s var(--ease);
  }
  .nav-link:hover { color: var(--terracotta-deep); }
  .nav-link[aria-current='page'] {
    border-color: var(--seal);
    color: var(--ink);
  }
  @media (max-width: 36rem) {
    .wordmark { display: none; }
  }
</style>
