---
import { getLocale, useTranslations, localizePath } from '../i18n/utils';
const year = new Date().getFullYear();
const locale = getLocale(Astro.url);
const t = useTranslations(locale);
const L = (p: string) => localizePath(p, locale);
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="brand-col">
        <div class="name">Agence&nbsp;L<span class="amp">&amp;</span>L</div>
      </div>

      <nav class="col" aria-label={t('footer.colSite')}>
        <span class="h">Plan du site</span>
        <a class="plain" href={L('/projets')}>{t('nav.projets')}</a>
        <a class="plain" href={L('/journal')}>{t('nav.journal')}</a>
        <a class="plain" href={L('/agence')}>{t('nav.agence')}</a>
        <a class="plain" href={L('/contact')}>{t('nav.contact')}</a>
      </nav>

      <div class="col">
        <span class="h">Atelier</span>
        <span>Paris&nbsp;—&nbsp;Normandie</span>
        <a class="plain" href="mailto:contact@agence-ll.fr">contact@agence-ll.fr</a>
      </div>

      <div class="col">
        <span class="h">Suivre</span>
        <span class="soon">LinkedIn <em>(à venir)</em></span>
        <span class="soon">Instagram <em>(à venir)</em></span>
        <a class="plain" href={L('/journal')}>{t('nav.journal')}</a>
      </div>
    </div>

    <div class="colophon">
      <span>© {year} Agence&nbsp;L&amp;L — {t('footer.rights')}</span>
      <span><a class="plain" href={L('/mentions-legales')}>{t('footer.mentions')}</a></span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--footer-bg, #1A1714);
    color: var(--paper);
    margin-top: clamp(3.5rem, 8vw, 6rem);
    padding-block: clamp(3rem, 6vw, 4.5rem) clamp(1.6rem, 3vw, 2.2rem);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: clamp(1.6rem, 4vw, 3rem);
    align-items: start;
  }

  .name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.5rem;
    line-height: 1.1;
    color: var(--paper);
  }
  .name .amp { font-style: italic; }

  .col {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: rgba(246, 242, 235, 0.78);
  }
  .col .h {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(246, 242, 235, 0.5);
    margin-bottom: 0.35rem;
  }
  .col a { color: rgba(246, 242, 235, 0.78); transition: color 0.2s var(--ease); }
  .col a:hover { color: var(--terracotta); }
  .col .soon { color: rgba(246, 242, 235, 0.55); }
  .col .soon em { font-style: italic; opacity: 0.7; }

  .colophon {
    margin-top: clamp(2.4rem, 5vw, 3.4rem);
    padding-top: 1.1rem;
    border-top: 1px solid rgba(246, 242, 235, 0.12);
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(246, 242, 235, 0.45);
  }
  .colophon a { color: rgba(246, 242, 235, 0.6); }
  .colophon a:hover { color: var(--terracotta); }

  @media (max-width: 52rem) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
    .brand-col { grid-column: 1 / -1; }
  }
  @media (max-width: 30rem) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
