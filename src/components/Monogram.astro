---
/**
 * Sceau / marque L&L — pieuvre en linogravure (validé avec Julien & Zoé).
 * Trois variantes :
 *   - variant="mark"  : pieuvre seule, sans anneau (header, favicon) — petit format.
 *   - variant="plain" : pieuvre + double cercle, SANS texte d'anneau (footer, formats moyens).
 *   - variant="seal"  : tampon complet (cercles + texte circulaire + pieuvre) — grand format (hero).
 * Couleur via currentColor (le parent décide : encre, terre cuite ou rouge sceau).
 * Les ventouses utilisent var(--paper) → réserve « gravée » sur fond papier.
 */
interface Props {
  variant?: 'mark' | 'plain' | 'seal';
  size?: number;
  title?: string;
  class?: string;
}
const { variant = 'seal', size = 120, title = 'Agence L&L', class: cls = '' } = Astro.props;
const uid = 'seal-' + Math.random().toString(36).slice(2, 8);
const showRings = variant === 'seal' || variant === 'plain';
const showRing = variant === 'seal';
const viewBox = variant === 'mark' ? '64 58 112 122' : '0 0 240 240';
const ringText = '· AGENCE L&L · ARCHITECTURE · ÉCOLOGIE · PARIS — NORMANDIE ';
---
<svg class={cls} width={size} height={size} viewBox={viewBox} role="img" aria-label={title} xmlns="http://www.w3.org/2000/svg">
  {showRing && (
    <defs>
      <path id={uid} d="M 120,22 A 98,98 0 1 1 119.9,22" fill="none" />
    </defs>
  )}
  {showRings && (
    <>
      <circle cx="120" cy="120" r="112" fill="none" stroke="currentColor" stroke-width="1.4" />
      <circle cx="120" cy="120" r="92" fill="none" stroke="currentColor" stroke-width="0.9" />
    </>
  )}
  {showRing && (
    <text style="font-family:var(--font-display);font-size:9.4px;font-weight:560;letter-spacing:1.5px;text-transform:uppercase;fill:currentColor;">
      <textPath href={`#${uid}`} startOffset="0" textLength="616" lengthAdjust="spacing">{ringText}</textPath>
    </text>
  )}
  <g fill="currentColor">
    <path d="M101,116 C90,108 80,108 74,116 C71,120 73,125 78,124 C82,123 86,120 92,121 C97,122 101,124 105,127 Z" opacity="0.92" />
    <path d="M139,116 C150,108 160,108 166,116 C169,120 167,125 162,124 C158,123 154,120 148,121 C143,122 139,124 135,127 Z" opacity="0.92" />
    <path fill-rule="evenodd" d="M102,127 C90,119 86,105 90,93 C95,77 108,69 120,69 C132,69 145,77 150,93 C154,105 150,119 138,127 C132,131 108,131 102,127 Z M99,101 a7,5 0 1,0 14,0 a7,5 0 1,0 -14,0 Z M127,101 a7,5 0 1,0 14,0 a7,5 0 1,0 -14,0 Z" />
    <rect x="101.5" y="99.5" width="9" height="3" rx="1.4" />
    <rect x="129.5" y="99.5" width="9" height="3" rx="1.4" />
    <path d="M101,124 C87,128 75,138 71,152 C68,162 71,170 79,172 C83,173 87,170 87,165 C82,166 77,162 79,154 C82,144 93,134 105,130 Z" />
    <path d="M107,127 C99,140 93,154 97,166 C100,174 108,174 110,167 C105,167 102,162 103,154 C104,146 109,137 114,131 Z" />
    <path d="M120,129 C117,144 116,158 121,170 C124,177 131,176 132,169 C127,168 125,162 125,153 C125,144 127,137 129,131 Z" />
    <path d="M133,127 C141,140 147,154 143,166 C140,174 132,174 130,167 C135,167 138,162 137,154 C136,146 131,137 126,131 Z" />
    <path d="M139,124 C153,128 165,138 169,152 C172,162 169,170 161,172 C157,173 153,170 153,165 C158,166 163,162 161,154 C158,144 147,134 135,130 Z" />
    <circle cx="119" cy="146" r="1.5" fill="var(--paper)" />
    <circle cx="120" cy="155" r="1.5" fill="var(--paper)" />
    <circle cx="122" cy="163" r="1.4" fill="var(--paper)" />
    <circle cx="104" cy="150" r="1.3" fill="var(--paper)" />
    <circle cx="136" cy="150" r="1.3" fill="var(--paper)" />
  </g>
</svg>
