---
// « Projet à la une » de l'accueil — îlot éditable Tina.
// La vedette est une RÉFÉRENCE (singleton accueil → projets) : cliquer le bloc
// dans l'admin ouvre le réglage « Projet à la une » ; changer la référence
// remplace la vedette sans toucher aux projets.
import { tinaField } from '@tinacms/astro/tina-field';
import { refSlug } from '../../lib/tina-data';
import { resolveProjetImage } from '../../lib/projet-images';
import { localizePath, type Locale } from '../../i18n/utils';

interface Props {
  accueil: any;
  lang?: string;
}
const { accueil, lang = 'fr' } = Astro.props;
const locale = (lang === 'en' ? 'en' : 'fr') as Locale;

const vedette = accueil?.projetVedette ?? null;
const slug = refSlug(vedette);
const cover = vedette ? await resolveProjetImage(slug, vedette.couverture, { width: 1600 }) : null;
const href = slug ? localizePath(`/projets/${slug}`, locale) : localizePath('/projets', locale);
---
{vedette && (
  <a class="featured plain" href={href} data-tina-field={tinaField(accueil, 'projetVedette')}>
    <div class="featured-visual">
      {cover ? (
        <img src={cover.src} width={cover.width} height={cover.height} alt={vedette.titre} />
      ) : (
        <div class="ph" aria-hidden="true">
          <span class="ph-cap">[ photo — {vedette.titre}, vue principale ]</span>
        </div>
      )}
    </div>
    <div class="featured-cap">
      <span class="f-titre">{vedette.titre}</span>
      <span class="f-meta">{vedette.lieu} · {vedette.annee}</span>
    </div>
  </a>
)}

<style>
  .featured { display: block; }
  .featured-visual {
    position: relative; aspect-ratio: 16 / 9; overflow: hidden;
    border: var(--rule); transition: border-color 0.25s var(--ease);
  }
  .featured-visual img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s var(--ease);
  }
  .featured:hover .featured-visual { border-color: var(--terracotta); }
  .featured:hover .featured-visual img { transform: scale(1.02); }
  .ph {
    width: 100%; height: 100%; display: grid; place-items: end start; padding: 1rem;
    background: repeating-linear-gradient(135deg, var(--ph1, #E7DFD0) 0 13px, var(--surface, #EFE9DE) 13px 26px);
  }
  .ph-cap {
    font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.06em;
    color: var(--stone); background: rgba(246, 242, 235, 0.72); padding: 0.3rem 0.6rem;
  }
  .featured-cap {
    display: flex; flex-wrap: wrap; align-items: baseline; justify-content: space-between;
    gap: var(--space-s); margin-top: var(--space-m);
  }
  .f-titre {
    font-family: var(--font-display); font-style: italic; font-weight: 500;
    font-size: clamp(1.5rem, 2.8vw, 2rem); color: var(--ink);
    transition: color 0.2s var(--ease);
  }
  .featured:hover .f-titre { color: var(--terracotta-deep); }
  .f-meta {
    font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.05em; color: var(--stone);
  }
</style>
