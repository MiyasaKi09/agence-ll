---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  projet: CollectionEntry<'projets'>;
}
const { projet } = Astro.props;
const d = projet.data;
const statutLabel: Record<string, string> = {
  concours: 'Concours',
  'étude': 'Étude',
  chantier: 'Chantier',
  'livré': 'Livré',
};
---
<a href={`/projets/${projet.id}`} class="card plain">
  <div class="visual">
    {d.couverture ? (
      <Image
        src={d.couverture}
        alt={d.titre}
        widths={[420, 720, 1040]}
        sizes="(max-width: 52rem) 100vw, 46vw"
        loading="lazy"
      />
    ) : (
      <div class="placeholder" aria-hidden="true">
        <span class="num">{d.numero}</span>
      </div>
    )}
  </div>

  <div class="info">
    <div class="topline">
      <span class="num small">{d.numero}</span>
      <span class="meta">{d.programme} · {d.annee}</span>
    </div>
    <h3 class="titre">{d.titre}</h3>
    <p class="resume">{d.resume}</p>
    <div class="footline">
      <span class="meta">{d.lieu}</span>
      <span class="tag">{statutLabel[d.statut] ?? d.statut}</span>
    </div>
  </div>
</a>

<style>
  .card {
    display: grid;
    gap: var(--space-s);
  }
  .visual { overflow: hidden; background: var(--paper-deep); aspect-ratio: 4 / 3; }
  .visual :global(img) {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s var(--ease), filter 0.6s var(--ease);
    filter: saturate(0.92);
  }
  .card:hover .visual :global(img) { transform: scale(1.03); filter: saturate(1); }

  .placeholder {
    width: 100%; height: 100%;
    display: grid; place-items: center;
    background:
      repeating-linear-gradient(45deg,
        color-mix(in srgb, var(--terracotta) 10%, var(--paper-deep)) 0 10px,
        var(--paper-deep) 10px 20px);
    border: var(--rule);
  }
  .placeholder .num { font-size: clamp(3rem, 8vw, 5rem); opacity: 0.85; }

  .topline, .footline {
    display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-s);
  }
  .num.small { font-size: var(--step-1); }
  .titre {
    font-size: var(--step-2);
    transition: color 0.2s var(--ease);
  }
  .card:hover .titre { color: var(--terracotta-deep); }
  .resume { color: var(--ink-soft); max-width: 42ch; }
  .footline { padding-top: var(--space-2xs); border-top: var(--rule); margin-top: var(--space-2xs); }
  .tag {
    font-family: var(--font-mono); font-size: var(--step--1);
    letter-spacing: 0.04em; color: var(--moss);
  }
</style>
