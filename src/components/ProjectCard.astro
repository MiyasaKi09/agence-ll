---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  projet: CollectionEntry<'projets'>;
}
const { projet } = Astro.props;
const d = projet.data;

const statutLabel: Record<string, string> = {
  concours: 'Concours',
  'étude': 'Étude',
  chantier: 'Chantier',
  'livré': 'Livré',
};

// Matière du placeholder choisie de façon déterministe (stable au build),
// pour varier les vignettes tant qu'il n'y a pas de vraie photo.
const matieres = ['chanvre', 'pise', 'bois'] as const;
const seed = [...projet.id].reduce((acc, c) => acc + c.charCodeAt(0), 0);
const matiere = matieres[seed % matieres.length];
---
<a href={`/projets/${projet.id}`} class="card plain">
  <span class="num" aria-hidden="true">N°{d.numero}</span>

  <div class="frame">
    {d.couverture ? (
      <Image
        src={d.couverture}
        alt={d.titre}
        widths={[420, 720, 1040]}
        sizes="(max-width: 56rem) 100vw, 46vw"
        loading="lazy"
      />
    ) : (
      <div class={`mat mat-${matiere} placeholder`}></div>
    )}
    <span class="scrim" aria-hidden="true"></span>
  </div>

  <div class="body">
    <h3 class="titre">{d.titre}</h3>
    <div class="meta-row">
      <span class="meta">{d.lieu}</span>
      <span class="sep meta" aria-hidden="true">/</span>
      <span class="meta">{d.annee}</span>
      <span class="sep meta" aria-hidden="true">/</span>
      <span class="meta">{d.programme}</span>
      <span class="statut">{statutLabel[d.statut] ?? d.statut}</span>
    </div>
  </div>
</a>

<style>
  .card { position: relative; display: block; }

  /* numéro manuscrit rouge, débordant le cadre en haut à gauche */
  .num {
    position: absolute;
    top: -22px;
    left: -10px;
    z-index: 3;
    font-family: var(--font-script);
    font-size: clamp(2rem, 4vw, 2.7rem);
    font-weight: 700;
    color: var(--seal);
    transform: rotate(-8deg);
    line-height: 1;
    pointer-events: none;
    text-shadow: 0 1px 0 color-mix(in srgb, var(--paper) 60%, transparent);
  }

  .frame {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border: var(--rule);
    background: var(--paper-deep);
    transition: border-color 0.25s var(--ease);
  }
  .frame :global(img) {
    width: 100%; height: 100%; object-fit: cover;
    filter: saturate(0.92);
    transition: transform 0.6s var(--ease), filter 0.6s var(--ease);
  }
  .placeholder { width: 100%; height: 100%; }
  .scrim {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(115deg, color-mix(in srgb, var(--ink) 12%, transparent), transparent 48%);
  }
  .card:hover .frame { border-color: var(--terracotta); }
  .card:hover .frame :global(img) { transform: scale(1.03); filter: saturate(1); }

  .body { padding-top: 1rem; }
  .titre {
    font-size: var(--step-1);
    margin-bottom: 0.5rem;
    transition: color 0.2s var(--ease);
  }
  .card:hover .titre { color: var(--terracotta-deep); }

  .meta-row { display: flex; flex-wrap: wrap; gap: 0.4ch 0.9ch; align-items: center; }
  .meta-row .sep { color: var(--terracotta); opacity: 0.7; }
  .statut {
    font-family: var(--font-mono); font-size: var(--step--1); letter-spacing: 0.04em;
    color: var(--moss);
    border: 1px solid color-mix(in srgb, var(--moss) 40%, transparent);
    padding: 0.05rem 0.45rem;
  }

  @media (max-width: 36rem) {
    .num { top: -18px; left: -4px; }
  }
</style>
