---
import Base from '../../layouts/Base.astro';
import TinaIsland from '@tinacms/astro/TinaIsland.astro';
import ArticleCorps from '../../components/islands/ArticleCorps.astro';
import { journalStaticPaths } from '../../lib/paths';
import { getArticle } from '../../lib/tina-data';
import { getLocale, useTranslations, localizePath } from '../../i18n/utils';

export const getStaticPaths = journalStaticPaths;

const { entry, plusRecent, plusAncien } = Astro.props;
const slug = entry.id;

const locale = getLocale(Astro.url);
const t = useTranslations(locale);
const L = (p: string) => localizePath(p, locale);

// Données via Tina (édition visuelle au clic sur la page).
const res = await getArticle(slug);
const a: any = res?.data?.journal ?? {};

const canonical = new URL(L(`/journal/${slug}`), Astro.site ?? Astro.url).toString();
const linkedInShare = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonical)}`;
---
<Base title={`${a.titre ?? 'Article'} — Journal — Agence L&L`} description={a.extrait ?? ''}>
  <article class="container">
    <div class="article">
      <a class="back plain" href={L('/journal')}>← {t('article.back').replace('← ', '')}</a>

      <TinaIsland name="article" params={{ slug, lang: locale }} wrapper={{ tag: 'div', className: 'article-island' }} primary>
        <ArticleCorps article={a} slug={slug} lang={locale} />
      </TinaIsland>

      <div class="share">
        <span class="share-label">{t('article.share')}</span>
        <a class="pill plain" href={linkedInShare} target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <button type="button" class="pill" id="copy-link" data-url={canonical}>{t('article.copy')}</button>
        {a.linkedInUrl && (
          <a class="also plain" href={a.linkedInUrl} target="_blank" rel="noopener noreferrer">{t('article.alsoLinkedIn')} ↗</a>
        )}
      </div>

      {(plusRecent || plusAncien) && (
        <nav class="prevnext" aria-label="Autres articles">
          <div class="pn pn-prev">
            {plusRecent && (
              <a class="plain" href={L(`/journal/${plusRecent.id}`)}>
                <span class="pn-label">← {t('article.newer').replace('← ', '')}</span>
                <span class="pn-titre">{plusRecent.titre}</span>
              </a>
            )}
          </div>
          <div class="pn pn-next">
            {plusAncien && (
              <a class="plain" href={L(`/journal/${plusAncien.id}`)}>
                <span class="pn-label">{t('article.older').replace(' →', '')} →</span>
                <span class="pn-titre">{plusAncien.titre}</span>
              </a>
            )}
          </div>
        </nav>
      )}
    </div>
  </article>

  <div class="toast" id="toast" role="status" aria-live="polite" hidden>{t('article.copied')}</div>
</Base>

<script>
  // Initialisé sur astro:page-load pour survivre aux navigations ClientRouter
  // (sinon « Copier le lien » serait mort sur un article atteint en interne).
  let timer: number | undefined;
  function initCopyLink() {
    const btn = document.getElementById('copy-link');
    const toast = document.getElementById('toast');
    if (!btn || btn.dataset.wired === '1') return;
    btn.dataset.wired = '1';
    btn.addEventListener('click', async () => {
      const url = btn.getAttribute('data-url') || location.href;
      try { await navigator.clipboard.writeText(url); }
      catch {
        const ta = document.createElement('textarea');
        ta.value = url; document.body.appendChild(ta); ta.select();
        (document as unknown as { execCommand: (c: string) => void }).execCommand('copy');
        ta.remove();
      }
      if (toast) {
        toast.hidden = false;
        requestAnimationFrame(() => toast.classList.add('is-on'));
        clearTimeout(timer);
        timer = window.setTimeout(() => { toast.classList.remove('is-on'); window.setTimeout(() => { toast.hidden = true; }, 250); }, 1800);
      }
    });
  }
  document.addEventListener('astro:page-load', initCopyLink);
</script>

<style>
  .article { max-width: 46rem; margin-inline: auto; padding-block: clamp(1.5rem, 4vw, 2.5rem) var(--space-2xl); }

  .back { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.05em; color: var(--stone); }
  .back:hover { color: var(--ink); }
  .article :global(.article-island) { display: block; }

  /* Partage — pilules arrondies */
  .share {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.7rem;
    border-top: var(--rule); padding-top: clamp(1.4rem, 3vw, 2rem); margin-top: clamp(2rem, 5vw, 3rem);
  }
  .share-label { font-family: var(--font-mono); font-size: 0.66rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--stone); }
  .pill {
    font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.04em;
    border: 1px solid var(--stone-light); padding: 0.5rem 1.1rem; border-radius: 999px; color: var(--ink-soft);
    transition: color 0.2s var(--ease), border-color 0.2s var(--ease);
  }
  .pill:hover { color: var(--ink); border-color: var(--ink); }
  .also { margin-left: auto; font-family: var(--font-mono); font-size: 0.68rem; color: var(--stone); }

  /* Précédent / suivant */
  .prevnext { display: flex; justify-content: space-between; gap: var(--space-m); margin-top: clamp(2.5rem, 6vw, 3.5rem); }
  .pn { max-width: 22ch; }
  .pn-next { text-align: right; margin-left: auto; }
  .pn-label { display: block; font-family: var(--font-mono); font-size: 0.64rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--stone); }
  .pn-titre { display: block; font-family: var(--font-display); font-weight: 500; font-size: 1.25rem; margin-top: 0.3rem; color: var(--ink); transition: color 0.2s var(--ease); }
  .pn a:hover .pn-titre { color: var(--terracotta-deep); }

  .toast {
    position: fixed; left: 50%; bottom: 1.5rem; transform: translate(-50%, 0.5rem);
    background: var(--ink); color: var(--paper);
    font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.04em; padding: 0.6rem 1rem; z-index: 80;
    opacity: 0; transition: opacity 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .toast.is-on { opacity: 1; transform: translate(-50%, 0); }

  @media (max-width: 38rem) {
    .prevnext { flex-direction: column; gap: var(--space-l); }
    .pn-next { text-align: left; margin-left: 0; }
  }
</style>
