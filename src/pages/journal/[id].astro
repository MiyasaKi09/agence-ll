---
import Base from '../../layouts/Base.astro';
import { Image } from 'astro:assets';
import { render } from 'astro:content';
import Axono from '../../components/Axono.astro';
import { journalStaticPaths } from '../../lib/paths';
import { dateLongue, tempsLecture } from '../../lib/journal';
import { teinteFor } from '../../lib/teinte';
import { getLocale, useTranslations, localizePath } from '../../i18n/utils';
import type { UIKey } from '../../i18n/ui';

export const getStaticPaths = journalStaticPaths;

const { entry, projetLie, plusRecent, plusAncien } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);

const locale = getLocale(Astro.url);
const t = useTranslations(locale);
const L = (p: string) => localizePath(p, locale);

const lecture = d.tempsLecture ?? tempsLecture(d.extrait);
const canonical = new URL(L(`/journal/${entry.id}`), Astro.site ?? Astro.url).toString();
const linkedInShare = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonical)}`;
---
<Base title={`${d.titre} — Journal — Agence L&L`} description={d.extrait}>
  <article class="container">
    <div class="article">
      <header class="art-head">
        <a class="back plain" href={L('/journal')}>← {t('article.back').replace('← ', '')}</a>
        <p class="meta-line">
          <span class="rubrique">{t(`rubrique.${d.rubrique}` as UIKey)}</span>
          <span class="sep" aria-hidden="true">·</span>
          <time datetime={d.date.toISOString()}>{dateLongue(d.date)}</time>
          <span class="sep" aria-hidden="true">·</span>
          <span>{lecture} {t('article.reading')}</span>
        </p>
        <h1>{d.titre}</h1>
        <p class="signature">{d.signature}</p>
      </header>

      {d.image ? (
        <figure class="hero">
          <Image src={d.image} alt={d.titre} widths={[600, 980, 1400]} sizes="(max-width: 46rem) 100vw, 46rem" />
        </figure>
      ) : (
        <div class="hero ph" role="img" aria-label={d.titre}>
          <span class="ph-cap">[ {d.imageLegende ?? 'photo — illustration de l’article'} ]</span>
        </div>
      )}

      <p class="chapo">{d.extrait}</p>

      <div class="prose">
        <Content />
      </div>

      {projetLie && (
        <a class="projet-lie plain" href={L(`/projets/${projetLie.id}`)}>
          <Axono id={projetLie.id} teinte={teinteFor(projetLie.id)} class="pl-axo" />
          <span class="pl-body">
            <span class="pl-label">{t('article.related')}</span>
            <span class="pl-titre">{projetLie.titre}</span>
            <span class="pl-meta">{projetLie.lieu} · {projetLie.annee} →</span>
          </span>
        </a>
      )}

      <div class="share">
        <span class="share-label">{t('article.share')}</span>
        <a class="pill plain" href={linkedInShare} target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <button type="button" class="pill" id="copy-link" data-url={canonical}>{t('article.copy')}</button>
        {d.linkedInUrl && (
          <a class="also plain" href={d.linkedInUrl} target="_blank" rel="noopener noreferrer">{t('article.alsoLinkedIn')} ↗</a>
        )}
      </div>

      {(plusRecent || plusAncien) && (
        <nav class="prevnext" aria-label="Autres articles">
          <div class="pn pn-prev">
            {plusRecent && (
              <a class="plain" href={L(`/journal/${plusRecent.id}`)}>
                <span class="pn-label">← {t('article.newer').replace('← ', '')}</span>
                <span class="pn-titre">{plusRecent.titre}</span>
              </a>
            )}
          </div>
          <div class="pn pn-next">
            {plusAncien && (
              <a class="plain" href={L(`/journal/${plusAncien.id}`)}>
                <span class="pn-label">{t('article.older').replace(' →', '')} →</span>
                <span class="pn-titre">{plusAncien.titre}</span>
              </a>
            )}
          </div>
        </nav>
      )}
    </div>
  </article>

  <div class="toast" id="toast" role="status" aria-live="polite" hidden>{t('article.copied')}</div>
</Base>

<script>
  // Initialisé sur astro:page-load pour survivre aux navigations ClientRouter
  // (sinon « Copier le lien » serait mort sur un article atteint en interne).
  let timer: number | undefined;
  function initCopyLink() {
    const btn = document.getElementById('copy-link');
    const toast = document.getElementById('toast');
    if (!btn || btn.dataset.wired === '1') return;
    btn.dataset.wired = '1';
    btn.addEventListener('click', async () => {
      const url = btn.getAttribute('data-url') || location.href;
      try { await navigator.clipboard.writeText(url); }
      catch {
        const ta = document.createElement('textarea');
        ta.value = url; document.body.appendChild(ta); ta.select();
        (document as unknown as { execCommand: (c: string) => void }).execCommand('copy');
        ta.remove();
      }
      if (toast) {
        toast.hidden = false;
        requestAnimationFrame(() => toast.classList.add('is-on'));
        clearTimeout(timer);
        timer = window.setTimeout(() => { toast.classList.remove('is-on'); window.setTimeout(() => { toast.hidden = true; }, 250); }, 1800);
      }
    });
  }
  document.addEventListener('astro:page-load', initCopyLink);
</script>

<style>
  .article { max-width: 46rem; margin-inline: auto; padding-block: clamp(1.5rem, 4vw, 2.5rem) var(--space-2xl); }

  .back { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.05em; color: var(--stone); }
  .back:hover { color: var(--ink); }
  .meta-line {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.6ch;
    font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--stone); margin-top: clamp(1.2rem, 3vw, 1.8rem);
  }
  .meta-line .rubrique { color: var(--terracotta); }
  .meta-line .sep { color: var(--stone-light); }
  .art-head h1 {
    font-family: var(--font-display); font-weight: 500; font-size: clamp(2rem, 4.4vw, 3rem);
    line-height: 1.08; color: var(--ink); margin-top: 0.6rem;
  }
  .signature {
    font-family: var(--font-display); font-style: italic; font-size: 1.15rem;
    color: var(--stone); margin-top: 0.8rem;
  }

  .hero { margin-block: clamp(1.6rem, 4vw, 2.4rem); }
  .hero :global(img) { width: 100%; aspect-ratio: 16 / 10; object-fit: cover; border: var(--rule); display: block; }
  .hero.ph {
    aspect-ratio: 16 / 10; display: grid; place-items: end start; padding: 0; border: var(--rule);
    background: repeating-linear-gradient(135deg, var(--ph1, #E7DFD0) 0 13px, var(--surface, #EFE9DE) 13px 26px);
  }
  .hero .ph-cap {
    font-family: var(--font-mono); font-size: 0.66rem; color: var(--stone);
    background: rgba(246, 242, 235, 0.72); padding: 0.3rem 0.6rem; margin: 1rem;
  }

  .chapo {
    font-family: var(--font-display); font-weight: 500; font-size: clamp(1.4rem, 2.6vw, 1.85rem);
    line-height: 1.3; color: var(--ink); margin-bottom: clamp(1.4rem, 3vw, 2rem); max-width: none;
  }

  /* Carte « Projet lié » */
  .projet-lie {
    display: flex; align-items: center; gap: 1.2rem;
    background: var(--paper-deep); border: var(--rule);
    padding: 1rem 1.2rem; margin-top: clamp(2rem, 5vw, 3rem);
    transition: border-color 0.2s var(--ease);
  }
  .projet-lie:hover { border-color: var(--terracotta); }
  .projet-lie :global(.pl-axo) { width: 80px; flex: none; aspect-ratio: 4 / 3; padding: 0; }
  .pl-body { display: flex; flex-direction: column; gap: 0.2rem; }
  .pl-label {
    font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--terracotta);
  }
  .pl-titre { font-family: var(--font-display); font-weight: 500; font-size: 1.3rem; color: var(--ink); }
  .pl-meta { font-family: var(--font-mono); font-size: 0.68rem; color: var(--stone); }
  .projet-lie:hover .pl-titre { color: var(--terracotta-deep); }

  /* Partage — pilules arrondies */
  .share {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.7rem;
    border-top: var(--rule); padding-top: clamp(1.4rem, 3vw, 2rem); margin-top: clamp(2rem, 5vw, 3rem);
  }
  .share-label { font-family: var(--font-mono); font-size: 0.66rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--stone); }
  .pill {
    font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.04em;
    border: 1px solid var(--stone-light); padding: 0.5rem 1.1rem; border-radius: 999px; color: var(--ink-soft);
    transition: color 0.2s var(--ease), border-color 0.2s var(--ease);
  }
  .pill:hover { color: var(--ink); border-color: var(--ink); }
  .also { margin-left: auto; font-family: var(--font-mono); font-size: 0.68rem; color: var(--stone); }

  /* Précédent / suivant */
  .prevnext { display: flex; justify-content: space-between; gap: var(--space-m); margin-top: clamp(2.5rem, 6vw, 3.5rem); }
  .pn { max-width: 22ch; }
  .pn-next { text-align: right; margin-left: auto; }
  .pn-label { display: block; font-family: var(--font-mono); font-size: 0.64rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--stone); }
  .pn-titre { display: block; font-family: var(--font-display); font-weight: 500; font-size: 1.25rem; margin-top: 0.3rem; color: var(--ink); transition: color 0.2s var(--ease); }
  .pn a:hover .pn-titre { color: var(--terracotta-deep); }

  .toast {
    position: fixed; left: 50%; bottom: 1.5rem; transform: translate(-50%, 0.5rem);
    background: var(--ink); color: var(--paper);
    font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.04em; padding: 0.6rem 1rem; z-index: 80;
    opacity: 0; transition: opacity 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .toast.is-on { opacity: 1; transform: translate(-50%, 0); }

  @media (max-width: 38rem) {
    .prevnext { flex-direction: column; gap: var(--space-l); }
    .pn-next { text-align: left; margin-left: 0; }
  }
</style>
