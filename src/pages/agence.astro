---
import Base from '../layouts/Base.astro';
import Monogram from '../components/Monogram.astro';
import { getAgence } from '../lib/site';
import { getLocale, useTranslations } from '../i18n/utils';

const locale = getLocale(Astro.url);
const t = useTranslations(locale);

// Textes éditables depuis le CMS (sinon valeurs par défaut). Voir src/lib/site.ts.
const { introParagraphes, savoirFaire, equipe, territoireTexte } = await getAgence();
---
<Base
  title="L’agence — Agence L&L"
  description="Agence L&L, un duo d'architectes entre Paris et la Normandie. Rénovation énergétique, logement, équipements publics, construction biosourcée."
>
  <!-- Manifeste -->
  <section class="section container manifeste">
    <p class="eyebrow">{t('home.lagence')}</p>
    <h1>Une architecture du déjà-là, sobre et <em>vivante</em>.</h1>
    <div class="manifeste-body prose">
      {introParagraphes.map((p) => <p>{p}</p>)}
    </div>
  </section>

  <!-- Savoir-faire -->
  <section class="section container" id="savoir-faire" aria-labelledby="sf-h">
    <div class="section-head">
      <h2 id="sf-h">Ce que nous faisons</h2>
      <span class="meta">{t('footer.savoirfaire')}</span>
    </div>
    <dl class="sf-list">
      {savoirFaire.map((s) => (
        <div class="sf-row">
          <dt>{s.titre}</dt>
          <dd>{s.description}</dd>
        </div>
      ))}
    </dl>
  </section>

  <!-- Équipe -->
  <section class="section container equipe" id="equipe" aria-labelledby="eq-h">
    <div class="section-head">
      <h2 id="eq-h">L&amp;L — deux Lenglet</h2>
      <span class="meta">{t('agence.duo')}</span>
    </div>
    <div class="equipe-grid">
      {equipe.map((m) => (
        <article class="membre stack">
          <div class="portrait" aria-hidden="true"></div>
          <h3>{m.nom}</h3>
          <p>{m.bio}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- Territoire -->
  <section class="section container territoire">
    <Monogram variant="plain" size={120} class="terr-seal" />
    <div>
      <p class="eyebrow">{t('agence.territoire')}</p>
      <h2>Entre Paris et la <em>Normandie</em>.</h2>
      <p class="lede">{territoireTexte}</p>
    </div>
  </section>
</Base>

<style>
  .manifeste h1 { margin-block: var(--space-s) var(--space-l); max-width: 18ch; }
  .manifeste-body { font-size: var(--step-1); }

  .sf-list { display: grid; gap: 0; }
  .sf-row {
    display: grid; grid-template-columns: 18rem 1fr; gap: var(--space-l);
    padding-block: var(--space-m); border-top: var(--rule); align-items: baseline;
  }
  .sf-row dt { font-family: var(--font-display); font-size: var(--step-1); font-variation-settings: 'opsz' 40, 'SOFT' 28; }
  .sf-row dd { color: var(--ink-soft); }

  .equipe-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-xl); }
  .portrait {
    aspect-ratio: 3 / 4; background: var(--paper-deep);
    border: var(--rule);
    background-image: repeating-linear-gradient(45deg,
      color-mix(in srgb, var(--moss) 8%, var(--paper-deep)) 0 12px,
      var(--paper-deep) 12px 24px);
  }
  .membre h3 { font-size: var(--step-2); }

  .territoire {
    display: grid; grid-template-columns: auto 1fr; gap: var(--space-xl);
    align-items: center; padding-block: var(--space-3xl);
  }
  .terr-seal { color: var(--terracotta-deep); }
  .territoire h2 { margin-block: var(--space-xs) var(--space-s); }

  @media (max-width: 52rem) {
    .sf-row { grid-template-columns: 1fr; gap: var(--space-2xs); }
    .equipe-grid { grid-template-columns: 1fr; gap: var(--space-l); }
    .territoire { grid-template-columns: 1fr; gap: var(--space-l); }
  }
</style>
