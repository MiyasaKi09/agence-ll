---
import Base from '../layouts/Base.astro';
import Monogram from '../components/Monogram.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const projetsAll = (await getCollection('projets', ({ data }) => !data.brouillon))
  .sort((a, b) => (a.data.ordre ?? 9999) - (b.data.ordre ?? 9999) || b.data.annee - a.data.annee);
// Projet à la une = le premier (ordre manuel, sinon plus récent)
const featured = projetsAll[0] ?? null;

const matieres = ['chanvre', 'pise', 'bois'] as const;
const matiere = featured
  ? matieres[[...featured.id].reduce((a, c) => a + c.charCodeAt(0), 0) % matieres.length]
  : 'pise';

// Le Journal est le cœur de l'accueil : on en montre 4.
const articles = (await getCollection('journal', ({ data }) => !data.brouillon))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);
---
<Base>
  <!-- ——— HERO : la thèse, compacte ——— -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <p class="eyebrow">Agence d'architecture · Paris&nbsp;—&nbsp;Normandie</p>
        <h1>Réparer, transformer, <em>prolonger</em> le déjà-là.</h1>
        <p class="lede">
          Une agence pour une architecture sobre — ancrée dans la matière,
          attentive au vivant, au service des collectivités et de l'habitat.
        </p>
        <a class="hero-cta plain" href="/journal">
          <span>Lire le journal</span><span class="arr" aria-hidden="true">→</span>
        </a>
      </div>

      <div class="seal-col">
        <Monogram variant="seal" size={210} title="Sceau de l'Agence L&L" />
      </div>
    </div>
  </section>

  <!-- ——— PROJET À LA UNE ——— -->
  {featured && (
    <section class="section container featured-sec" aria-labelledby="featured-h">
      <p class="eyebrow">Projet à la une</p>
      <a class="featured plain" href={`/projets/${featured.id}`}>
        <span class="f-num num" aria-hidden="true">N°{featured.data.numero}</span>
        <div class="featured-visual">
          {featured.data.couverture ? (
            <Image
              src={featured.data.couverture}
              alt={featured.data.titre}
              widths={[720, 1200, 1800]}
              sizes="(max-width: 82rem) 100vw, 1240px"
            />
          ) : (
            <div class={`featured-ph mat mat-${matiere}`} aria-hidden="true">
              <span class="ph-cap">[ photo du projet — épreuve à venir ]</span>
            </div>
          )}
        </div>
        <div class="featured-cap">
          <span id="featured-h" class="f-titre">{featured.data.titre}</span>
          <span class="f-meta meta">{featured.data.lieu} · {featured.data.annee} →</span>
        </div>
      </a>
    </section>
  )}

  <!-- ——— MANIFESTE ——— -->
  <section class="section container manifeste" aria-labelledby="manifeste-h">
    <p class="eyebrow m-label">L'agence</p>
    <div class="m-body">
      <h2 id="manifeste-h">
        Nous partons toujours de l'existant — du bâti, du sol, du climat — pour
        faire mieux avec <em>moins</em>.
      </h2>
      <p>
        Rénovation énergétique, logement, équipements publics : une pratique sobre,
        des matières biosourcées, et une attention constante au vivant, du diagnostic
        au chantier.
      </p>
      <a class="m-link" href="/agence">En savoir plus sur l'agence →</a>
    </div>
  </section>

  <!-- ——— AU JOURNAL (le cœur de l'accueil) ——— -->
  <section class="section container journal-home" id="journal" aria-labelledby="journal-h">
    <div class="section-head">
      <h2 id="journal-h">Au journal</h2>
      <a class="section-link plain" href="/journal">
        <span>Tout voir</span><span class="arr" aria-hidden="true">→</span>
      </a>
    </div>

    {articles.length > 0 ? (
      <div class="journal-grid">
        {articles.map((article) => <ArticleCard article={article} />)}
      </div>
    ) : (
      <p class="lede">Les premiers billets seront publiés ici très bientôt.</p>
    )}
  </section>

  <!-- ——— CONTACT ——— -->
  <section class="section container contact" id="contact" aria-labelledby="contact-h">
    <div class="contact-inner">
      <div>
        <h2 id="contact-h">Un lieu, un programme, une <em>intention</em>&nbsp;?</h2>
        <a class="contact-cta plain" href="/contact">
          <span>Écrire à l'agence</span><span class="arr" aria-hidden="true">→</span>
        </a>
      </div>
      <div class="contact-side">
        <strong>Agence L&amp;L</strong><br />
        Julien&nbsp;&amp;&nbsp;Zoé Lenglet<br />
        Architectes DE · HMONP<br />
        Paris&nbsp;—&nbsp;Normandie<br />
        <a href="mailto:contact@agence-ll.fr">contact@agence-ll.fr</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* HERO */
  .hero { padding-block: clamp(2.4rem, 6vw, 4.5rem) clamp(1.5rem, 4vw, 2.5rem); }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
  }
  .hero h1 { margin-top: 0.9rem; max-width: 14ch; }
  .hero .lede { max-width: 34ch; margin-top: 1.5rem; }
  .hero-cta {
    display: inline-flex; align-items: center; gap: 0.6ch;
    margin-top: 1.9rem;
    font-family: var(--font-mono); font-size: var(--step--1); letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--ink);
    border-bottom: 1.5px solid var(--ink);
    padding-bottom: 0.25rem;
    transition: gap 0.25s var(--ease), border-color 0.25s var(--ease), color 0.25s var(--ease);
  }
  .hero-cta .arr { color: var(--seal); transition: transform 0.25s var(--ease); }
  .hero-cta:hover { gap: 1.1ch; border-color: var(--seal); }
  .hero-cta:hover .arr { transform: translateX(3px); }

  .seal-col { display: flex; justify-content: flex-end; color: var(--seal); }
  .seal-col :global(svg) {
    width: clamp(160px, 20vw, 220px); height: auto;
    animation: press 0.7s var(--ease) both 0.15s;
    transform-origin: center;
  }
  @keyframes press {
    from { opacity: 0; transform: scale(1.06) rotate(-3deg); }
    to   { opacity: 1; transform: scale(1) rotate(0); }
  }

  /* PROJET À LA UNE */
  .featured-sec { padding-block: clamp(1.5rem, 4vw, 3rem); }
  .featured-sec .eyebrow { margin-bottom: var(--space-s); }
  .featured { position: relative; display: block; }
  .f-num { position: absolute; top: -24px; left: -10px; z-index: 3; font-size: clamp(2.2rem, 4vw, 3rem); }
  .featured-visual {
    aspect-ratio: 21 / 9; min-height: 240px; overflow: hidden; border: var(--rule);
    transition: border-color 0.25s var(--ease);
  }
  .featured-visual :global(img) {
    width: 100%; height: 100%; object-fit: cover; filter: saturate(0.92);
    transition: transform 0.6s var(--ease), filter 0.6s var(--ease);
  }
  .featured:hover .featured-visual { border-color: var(--terracotta); }
  .featured:hover .featured-visual :global(img) { transform: scale(1.02); filter: saturate(1); }
  .featured-ph { width: 100%; height: 100%; display: grid; place-items: center; }
  .featured-ph .ph-cap {
    position: relative; z-index: 2;
    font-family: var(--font-mono); font-size: var(--step--1); color: var(--paper);
    background: rgba(28, 26, 23, 0.55); padding: 0.3rem 0.7rem; letter-spacing: 0.04em;
  }
  .featured-cap {
    display: flex; flex-wrap: wrap; align-items: baseline; justify-content: space-between;
    gap: var(--space-s); margin-top: var(--space-s);
  }
  .f-titre {
    font-family: var(--font-display); font-style: italic; font-size: var(--step-2);
    color: var(--ink); transition: color 0.2s var(--ease);
  }
  .featured:hover .f-titre { color: var(--terracotta-deep); }

  /* MANIFESTE */
  .manifeste {
    display: grid; grid-template-columns: 180px 1fr; gap: clamp(1.5rem, 4vw, 2.5rem);
    border-top: var(--rule); border-bottom: var(--rule);
  }
  .m-label { padding-top: 0.4rem; }
  .m-body h2 { font-size: var(--step-2); max-width: 24ch; }
  .m-body p { margin-top: var(--space-m); color: var(--ink-soft); font-size: var(--step-1); max-width: 52ch; }
  .m-link {
    display: inline-block; margin-top: var(--space-m);
    font-family: var(--font-mono); font-size: var(--step--1); letter-spacing: 0.04em;
  }

  /* AU JOURNAL — le cœur de l'accueil */
  .journal-grid {
    display: grid; grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(2rem, 4vw, 3rem) clamp(1.6rem, 4vw, 2.6rem);
  }

  /* CONTACT */
  .contact-inner {
    border-top: 1px solid var(--ink);
    padding-top: clamp(2rem, 5vw, 3.5rem);
    display: grid; grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 3rem); align-items: end;
  }
  .contact-inner h2 {
    font-size: var(--step-3); line-height: 1.05; max-width: 16ch;
    font-variation-settings: 'opsz' 120, 'SOFT' 30;
  }
  .contact-cta {
    display: inline-flex; align-items: center; gap: 0.6ch; margin-top: 1.6rem;
    font-family: var(--font-mono); font-size: var(--step--1); letter-spacing: 0.05em;
    text-transform: uppercase;
    border-bottom: 1.5px solid var(--ink); padding-bottom: 0.3rem;
    transition: gap 0.25s var(--ease), border-color 0.25s var(--ease);
  }
  .contact-cta .arr { color: var(--seal); }
  .contact-cta:hover { gap: 1.1ch; border-color: var(--seal); }
  .contact-side {
    font-family: var(--font-mono); font-size: var(--step--1); line-height: 1.9;
    color: var(--ink-soft); letter-spacing: 0.03em;
  }
  .contact-side strong { color: var(--ink); font-weight: 600; }

  /* Responsive */
  @media (max-width: 56rem) {
    .hero-grid { grid-template-columns: 1fr; }
    .seal-col { justify-content: flex-start; order: -1; }
    .manifeste { grid-template-columns: 1fr; gap: var(--space-s); }
    .journal-grid { grid-template-columns: 1fr; gap: 2.6rem; }
    .contact-inner { grid-template-columns: 1fr; align-items: start; }
  }
  @media (max-width: 38rem) {
    .featured-visual { aspect-ratio: 4 / 3; }
  }
</style>
