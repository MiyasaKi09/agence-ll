---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import TinaIsland from '@tinacms/astro/TinaIsland.astro';
import AccueilVedette from '../components/islands/AccueilVedette.astro';
import Axono from '../components/Axono.astro';
import { teinteFor } from '../lib/teinte';
import { getAccueil, getProjetsConnection } from '../lib/tina-data';
import { resolveContentImage } from '../lib/projet-images';
import { getLocale, useTranslations, localizePath } from '../i18n/utils';

const locale = getLocale(Astro.url);
const t = useTranslations(locale);
const L = (p: string) => localizePath(p, locale);

// Projet à la une : référence « projetVedette » du singleton accueil (Tina).
// Si la référence est vide (ex. projet vedette supprimé depuis l'admin), on
// retombe sur le projet le plus en avant (ordre puis année) pour ne pas
// perdre la section — l'îlot reste lié au réglage, cliquable en édition.
const accueilRes = await getAccueil();
const accueil = accueilRes?.data?.accueil ?? null;
let vedette: any = accueil?.projetVedette ?? null;
if (!vedette) {
  const conn = await getProjetsConnection();
  const nodes = (conn?.data?.projetsConnection?.edges ?? [])
    .map((e: any) => e?.node)
    .filter((n: any) => n && !n.brouillon);
  nodes.sort(
    (a: any, b: any) =>
      (a.ordre ?? 9999) - (b.ordre ?? 9999) || (b.annee ?? 0) - (a.annee ?? 0),
  );
  vedette = nodes[0] ?? null;
}

const projetsAll = (await getCollection('projets', ({ data }) => !data.brouillon))
  .sort((a, b) => (a.data.ordre ?? 9999) - (b.data.ordre ?? 9999) || b.data.annee - a.data.annee);
const projetsRecents = await Promise.all(
  projetsAll.slice(0, 3).map(async (p) => ({
    ...p,
    axoSrc: (await resolveContentImage('projets', p.id, p.data.axonometrie, { width: 640 }))?.src,
  })),
);

const articlesRaw = (await getCollection('journal', ({ data }) => !data.brouillon))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);
// image de carte : nom colocalisé ou média Tina (/uploads/…), résolue/optimisée
const articles = await Promise.all(
  articlesRaw.map(async (a) => ({
    ...a,
    img: await resolveContentImage('journal', a.id, a.data.image, { width: 640 }),
  })),
);

// Rubrique → libellé court majuscule (comme le design)
const RUB: Record<string, string> = {
  chantiers: 'Chantier', reflexions: 'Réflexion', presse: 'Presse', distinctions: 'Distinction',
};
// Date courte JJ.MM.AA
const dShort = (d: Date) =>
  `${String(d.getDate()).padStart(2, '0')}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getFullYear()).slice(-2)}`;
---
<Base>
  <!-- ——— PROJET À LA UNE (îlot Tina : référence « projetVedette ») ——— -->
  {vedette && (
    <section class="section container featured-sec" aria-labelledby="featured-h">
      <div class="eyebrow-row">
        <span id="featured-h" class="eyebrow">{t('home.projetUne')}</span>
        <a class="row-link plain" href={L('/projets')}>{t('home.tousProjets')} →</a>
      </div>

      <TinaIsland name="accueil" params={{ lang: locale }} wrapper={{ tag: 'div', className: 'vedette-island' }} primary>
        <AccueilVedette accueil={accueil} vedette={vedette} lang={locale} />
      </TinaIsland>
    </section>
  )}

  <!-- ——— AU JOURNAL ——— -->
  {articles.length > 0 && (
    <section class="section container" id="journal" aria-labelledby="journal-h">
      <div class="head-row">
        <h2 id="journal-h">{t('home.auJournal')}</h2>
        <a class="row-link plain" href={L('/journal')}>{t('cta.toutVoir')} →</a>
      </div>

      <div class="journal-grid">
        {articles.map((a) => (
          <a class="jcard plain" href={L(`/journal/${a.id}`)}>
            <div class="jcard-visual">
              {a.img ? (
                <img src={a.img.src} width={a.img.width} height={a.img.height} alt={a.data.titre} loading="lazy" />
              ) : (
                <div class="ph" aria-hidden="true"></div>
              )}
            </div>
            <p class="jcard-meta">
              <span class="rub">{RUB[a.data.rubrique] ?? a.data.rubrique}</span>
              <span class="dot" aria-hidden="true">·</span>
              <time datetime={a.data.date.toISOString()}>{dShort(a.data.date)}</time>
            </p>
            <h3 class="jcard-titre">{a.data.titre}</h3>
            <p class="jcard-extrait">{a.data.extrait}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- ——— PROJETS RÉCENTS ——— -->
  {projetsRecents.length > 0 && (
    <section class="section container" aria-labelledby="recents-h">
      <div class="head-row">
        <h2 id="recents-h">{t('home.projetsRecents')}</h2>
        <a class="row-link plain" href={L('/projets')}>{t('home.voirGrille')} →</a>
      </div>

      <div class="recents-grid">
        {projetsRecents.map((p) => (
          <a class="rcard plain" href={L(`/projets/${p.id}`)}>
            <Axono id={p.id} src={p.axoSrc} teinte={teinteFor(p.id)} class="rcard-axo" />
            <h3 class="rcard-titre">{p.data.titre}</h3>
            <p class="rcard-meta">{p.data.lieu} · {p.data.annee}</p>
          </a>
        ))}
      </div>
    </section>
  )}
</Base>

<style>
  /* Lignes d'en-tête de section */
  .eyebrow-row, .head-row {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: var(--space-m); margin-bottom: clamp(1.2rem, 3vw, 1.8rem);
  }
  .eyebrow {
    font-family: var(--font-mono); font-size: 0.7rem; font-weight: 500;
    letter-spacing: 0.18em; text-transform: uppercase; color: var(--terracotta);
  }
  .head-row h2 {
    font-family: var(--font-display); font-weight: 500;
    font-size: clamp(1.8rem, 3.4vw, 2.3rem); line-height: 1.1; color: var(--ink);
  }
  .row-link {
    font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.08em;
    color: var(--stone); white-space: nowrap; transition: color 0.2s var(--ease);
  }
  .row-link:hover { color: var(--ink); }

  /* Placeholder tramé (diagonale) — comme le design */
  .ph {
    width: 100%; height: 100%; display: grid; place-items: center;
    background: repeating-linear-gradient(135deg, var(--ph1, #E7DFD0) 0 13px, var(--surface, #EFE9DE) 13px 26px);
  }
  .ph-cap {
    font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.06em;
    color: var(--stone); background: rgba(246, 242, 235, 0.72); padding: 0.3rem 0.6rem;
  }

  /* PROJET À LA UNE — le bloc lui-même vit dans l'îlot AccueilVedette */
  .featured-sec { padding-top: clamp(2rem, 5vw, 3.4rem); }

  /* AU JOURNAL */
  .journal-grid {
    display: grid; grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1.6rem, 3.5vw, 2.6rem) clamp(1.4rem, 3vw, 2.2rem);
  }
  .jcard-visual { aspect-ratio: 3 / 2; overflow: hidden; border: var(--rule); margin-bottom: 0.9rem; }
  .jcard-visual :global(img) { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s var(--ease); }
  .jcard:hover .jcard-visual :global(img) { transform: scale(1.03); }
  .jcard-meta {
    font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--stone); display: flex; gap: 0.6ch; align-items: center;
  }
  .jcard-meta .rub { color: var(--terracotta); }
  .jcard-meta .dot { opacity: 0.5; }
  .jcard-titre {
    font-family: var(--font-display); font-weight: 500; font-size: 1.4rem; line-height: 1.15;
    color: var(--ink); margin-top: 0.5rem; transition: color 0.2s var(--ease);
  }
  .jcard:hover .jcard-titre { color: var(--terracotta-deep); }
  .jcard-extrait {
    font-family: var(--font-body); font-size: 0.92rem; line-height: 1.5;
    color: var(--ink-soft); margin-top: 0.5rem; max-width: 42ch;
  }

  /* PROJETS RÉCENTS */
  .recents-grid {
    display: grid; grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1.6rem, 4vw, 3rem);
  }
  .rcard :global(.rcard-axo) { margin-block: 0.2rem; }
  .rcard:hover :global(.axono) { transform: translateY(-4px); }
  .rcard-titre {
    font-family: var(--font-display); font-weight: 500; font-size: 1.4rem; line-height: 1.15;
    color: var(--ink); margin-top: 0.4rem; transition: color 0.2s var(--ease);
  }
  .rcard:hover .rcard-titre { color: var(--terracotta-deep); }
  .rcard-meta {
    font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.05em;
    color: var(--stone); margin-top: 0.3rem;
  }

  /* Responsive */
  @media (max-width: 52rem) {
    .journal-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .recents-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
  @media (max-width: 34rem) {
    .journal-grid { grid-template-columns: 1fr; }
  }
</style>
