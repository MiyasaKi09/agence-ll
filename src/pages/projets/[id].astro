---
import Base from '../../layouts/Base.astro';
import { Image } from 'astro:assets';
import { render, getCollection } from 'astro:content';
import Axono from '../../components/Axono.astro';
import { projetStaticPaths } from '../../lib/paths';
import { teinteFor, teintePageVars } from '../../lib/teinte';
import { getLocale, useTranslations, localizePath } from '../../i18n/utils';
import type { UIKey } from '../../i18n/ui';

export const getStaticPaths = projetStaticPaths;

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);

const locale = getLocale(Astro.url);
const t = useTranslations(locale);
const L = (p: string) => localizePath(p, locale);

// Voisins (précédent / suivant) dans l'ordre d'affichage
const all = (await getCollection('projets', ({ data }) => !data.brouillon))
  .sort((a, b) => (a.data.ordre ?? 9999) - (b.data.ordre ?? 9999) || b.data.annee - a.data.annee);
const idx = all.findIndex((p) => p.id === entry.id);
const prev = idx > 0 ? all[idx - 1] : null;
const next = idx >= 0 && idx < all.length - 1 ? all[idx + 1] : null;
const axIndex = (e: typeof entry) => all.findIndex((p) => p.id === e.id);

const fiche = [
  [t('fiche.programme'), d.programme],
  [t('fiche.surface'), d.surface],
  [t('fiche.mo'), d.maitrise_ouvrage],
  ['Mission', (d as any).mission],
  ['Équipe', (d as any).equipe],
  ['Matériaux', (d as any).materiaux],
  [t('fiche.statut'), t(`statut.${d.statut}` as UIKey)],
].filter(([, v]) => Boolean(v)) as [string, string][];

const galCount = d.galerie?.length ?? 0;
const teinte = teinteFor(entry.id);
---
<Base title={`${d.titre} — Agence L&L`} description={d.resume} theme={teintePageVars(teinte)}>
  <article class="container">
    <a class="back plain" href={L('/projets')}>← {t('projet.back').replace('← ', '')}</a>

    <!-- Hero -->
    <div class="hero">
      {d.couverture ? (
        <Image src={d.couverture} alt={d.titre} widths={[720, 1200, 1800]} sizes="100vw" />
      ) : (
        <div class="ph hero-ph" role="img" aria-label={d.titre}>
          <span class="ph-cap">[ photo — {d.titre}, vue principale ]</span>
        </div>
      )}
      {galCount > 0 && <span class="voir">⤢ Voir les images · {galCount}</span>}
    </div>

    <!-- Titre -->
    <p class="kicker">{d.programme} · {t(`statut.${d.statut}` as UIKey)}</p>
    <h1>{d.titre}</h1>
    <p class="loc">{d.lieu} · {d.annee}</p>

    <!-- Corps + fiche -->
    <div class="body-grid">
      <div class="body-col">
        <p class="lede">{d.resume}</p>
        <div class="prose"><Content /></div>
      </div>

      <aside class="aside">
        <div class="plan">
          <span class="aside-h">Plan de situation</span>
          <div class="plan-box">
            <span class="compass" aria-hidden="true">↑<br />N</span>
            <svg class="plan-svg" viewBox="0 0 320 240" role="img" aria-label="Plan de situation" preserveAspectRatio="xMidYMid meet">
              <rect width="320" height="240" fill="var(--ph1)" />
              <!-- parcelles voisines -->
              <rect x="22" y="22" width="74" height="74" fill="var(--paper)" stroke="var(--stone-light)" stroke-width="1.4" />
              <rect x="138" y="22" width="78" height="58" fill="var(--paper)" stroke="var(--stone-light)" stroke-width="1.4" />
              <rect x="234" y="22" width="64" height="58" fill="var(--paper)" stroke="var(--stone-light)" stroke-width="1.4" />
              <rect x="22" y="144" width="74" height="74" fill="var(--paper)" stroke="var(--stone-light)" stroke-width="1.4" />
              <rect x="234" y="150" width="64" height="68" fill="var(--paper)" stroke="var(--stone-light)" stroke-width="1.4" />
              <!-- parcelle du projet (surlignée dans la teinte) -->
              <rect x="138" y="138" width="78" height="80" fill="var(--teinte-accent, var(--terracotta))" stroke="var(--ink)" stroke-width="1.6" />
            </svg>
          </div>
        </div>

        <dl class="fiche">
          {fiche.map(([k, v]) => (
            <div class="fiche-row">
              <dt>{k}</dt>
              <dd>{v}</dd>
            </div>
          ))}
        </dl>
      </aside>
    </div>

    <!-- Galerie -->
    {galCount > 0 && (
      <div class="galerie">
        {d.galerie!.map((img) => (
          <figure>
            <Image src={img.src} alt={img.alt} widths={[800, 1200, 1800]} sizes="100vw" loading="lazy" />
            {img.alt && <figcaption>{img.alt}</figcaption>}
          </figure>
        ))}
      </div>
    )}

    <!-- Précédent / suivant -->
    {(prev || next) && (
      <nav class="prevnext" aria-label="Autres projets">
        <div class="pn">
          {prev && (
            <a class="plain pn-a" href={L(`/projets/${prev.id}`)}>
              <Axono i={axIndex(prev)} teinte={teinteFor(prev.id)} class="pn-axo" />
              <span class="pn-txt"><span class="pn-l">← Précédent</span><span class="pn-t">{prev.data.titre}</span></span>
            </a>
          )}
        </div>
        <div class="pn pn-next">
          {next && (
            <a class="plain pn-a" href={L(`/projets/${next.id}`)}>
              <span class="pn-txt"><span class="pn-l">Suivant →</span><span class="pn-t">{next.data.titre}</span></span>
              <Axono i={axIndex(next)} teinte={teinteFor(next.id)} class="pn-axo" />
            </a>
          )}
        </div>
      </nav>
    )}
  </article>
</Base>

<style>
  article { padding-block: clamp(1.2rem, 3vw, 2rem) clamp(2.5rem, 6vw, 4rem); }
  .back { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.05em; color: var(--stone); }
  .back:hover { color: var(--ink); }

  .ph {
    background: repeating-linear-gradient(135deg, var(--ph1, #E7DFD0) 0 13px, var(--surface, #EFE9DE) 13px 26px);
    display: grid; place-items: end start;
  }
  .ph-cap {
    font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.06em;
    color: var(--stone); background: rgba(246, 242, 235, 0.72); padding: 0.3rem 0.6rem; margin: 1rem;
  }
  .hero { position: relative; margin-top: 1rem; border: var(--rule); overflow: hidden; }
  .hero :global(img) { width: 100%; aspect-ratio: 16 / 8; object-fit: cover; display: block; }
  .hero-ph { aspect-ratio: 16 / 8; }
  .voir {
    position: absolute; top: 1rem; right: 1rem;
    font-family: var(--font-mono); font-size: 0.64rem; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--paper); background: rgba(26, 23, 20, 0.78); padding: 0.45rem 0.8rem;
  }

  .kicker {
    font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--teinte-accent, var(--terracotta)); margin-top: clamp(1.6rem, 4vw, 2.4rem);
  }
  h1 {
    font-family: var(--font-display); font-weight: 500; font-size: clamp(2.2rem, 5vw, 3.4rem);
    line-height: 1.05; color: var(--ink); margin-top: 0.5rem;
  }
  .loc { font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.05em; color: var(--stone); margin-top: 0.7rem; }

  .body-grid {
    display: grid; grid-template-columns: 1fr 18rem; gap: clamp(2rem, 5vw, 4rem);
    margin-top: clamp(2rem, 5vw, 3rem); align-items: start;
  }
  .lede {
    font-family: var(--font-display); font-style: italic; font-weight: 500;
    font-size: clamp(1.3rem, 2.4vw, 1.7rem); line-height: 1.3; color: var(--ink); margin-bottom: 1.4rem; max-width: none;
  }
  .body-col .prose { max-width: none; }

  .aside-h {
    font-family: var(--font-mono); font-size: 0.64rem; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--stone); display: block; margin-bottom: 0.6rem;
  }
  .plan-box {
    position: relative; border: var(--rule); aspect-ratio: 4 / 3; overflow: hidden;
    background: var(--surface); margin-bottom: 1.6rem;
  }
  .plan-svg { width: 100%; height: 100%; display: block; }
  .compass {
    position: absolute; top: 0.5rem; right: 0.6rem; font-family: var(--font-mono);
    font-size: 0.6rem; line-height: 1; color: var(--stone); text-align: center;
  }
  .fiche { display: grid; }
  .fiche-row { padding-block: 0.7rem; border-top: var(--rule); }
  .fiche-row dt {
    font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--stone);
  }
  .fiche-row dd { font-family: var(--font-body); font-size: 0.95rem; color: var(--ink); margin-top: 0.25rem; }

  .galerie { display: grid; gap: clamp(1rem, 2vw, 1.5rem); margin-top: clamp(2.5rem, 6vw, 4rem); }
  .galerie :global(img) { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; border: var(--rule); display: block; }
  .galerie figcaption { font-family: var(--font-mono); font-size: 0.66rem; color: var(--stone); margin-top: 0.5rem; }

  .prevnext {
    display: flex; justify-content: space-between; gap: var(--space-l);
    margin-top: clamp(3rem, 7vw, 5rem); padding-top: clamp(1.6rem, 4vw, 2.4rem); border-top: var(--rule);
  }
  .pn-a { display: inline-flex; align-items: center; gap: 1rem; }
  .pn-next .pn-a { flex-direction: row; }
  .pn-next { text-align: right; margin-left: auto; }
  .pn-next .pn-txt { align-items: flex-end; }
  .pn-txt { display: flex; flex-direction: column; }
  .pn-l { font-family: var(--font-mono); font-size: 0.64rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--stone); }
  .pn-t { font-family: var(--font-display); font-weight: 500; font-size: 1.3rem; color: var(--ink); transition: color 0.2s var(--ease); margin-top: 0.2rem; }
  .pn-a:hover .pn-t { color: var(--terracotta-deep); }
  .pn-a :global(.pn-axo) { width: 70px; flex: none; }

  @media (max-width: 52rem) {
    .body-grid { grid-template-columns: 1fr; gap: 2rem; }
    .aside { order: 2; }
  }
  @media (max-width: 40rem) {
    .prevnext { flex-direction: column; gap: 1.5rem; }
    .pn-next, .pn-next .pn-txt { text-align: left; align-items: flex-start; margin-left: 0; }
    .pn-next .pn-a { flex-direction: row-reverse; justify-content: flex-end; }
  }
</style>
