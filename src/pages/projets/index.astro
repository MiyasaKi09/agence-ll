---
import Base from '../../layouts/Base.astro';
import Axono from '../../components/Axono.astro';
import { getCollection } from 'astro:content';
import { teinteFor } from '../../lib/teinte';
import { getLocale, useTranslations, localizePath } from '../../i18n/utils';

const locale = getLocale(Astro.url);
const t = useTranslations(locale);
const L = (p: string) => localizePath(p, locale);

const projets = (await getCollection('projets', ({ data }) => !data.brouillon))
  .sort((a, b) => (a.data.ordre ?? 9999) - (b.data.ordre ?? 9999) || b.data.annee - a.data.annee);

// Catégorie pour les filtres (déduite du programme / des tags)
function cat(p: typeof projets[number]): string {
  const s = `${p.data.programme} ${p.data.tags.join(' ')}`.toLowerCase();
  if (s.includes('logement')) return 'logements';
  if (s.includes('équipement') || s.includes('equipement') || s.includes('école') || s.includes('ecole') || s.includes('médiathèque') || s.includes('mediatheque')) return 'equipements';
  if (s.includes('rénovation') || s.includes('renovation') || s.includes('réhab') || s.includes('rehab')) return 'renovation';
  return 'neuf';
}
const filters = [
  { key: 'tous', label: 'Tous' },
  { key: 'logements', label: 'Logements' },
  { key: 'equipements', label: 'Équipements' },
  { key: 'renovation', label: 'Rénovation' },
  { key: 'neuf', label: 'Neuf' },
];

// Pins de la carte — positions à l'intérieur du blob Île-de-France (du design)
const PINS = [
  [150, 118], [188, 90], [132, 196], [210, 150],
  [100, 140], [170, 168], [120, 92], [205, 118],
];
---
<Base
  title="Projets — Agence L&L"
  description="Réalisations et études de l'Agence L&L : rénovation énergétique, logement, équipements publics, entre Paris et la Normandie."
>
  <section class="section container">
    <div class="proj-head">
      <div class="filters-wrap">
        <div class="filters" role="tablist" aria-label="Filtrer les projets">
          {filters.map((f) => (
            <button class="chip-link" data-filter={f.key} aria-pressed={f.key === 'tous' ? 'true' : 'false'}>{f.label}</button>
          ))}
        </div>
        <div class="sort-row">
          <span class="sort">Trier : plus récents ↓</span>
          <span class="zone">Toute l’Île-de-France</span>
        </div>
      </div>

      <div class="map-wrap" aria-hidden="true">
        <span class="map-label">Carte des projets</span>
        <svg class="map" viewBox="0 0 300 240" role="img" preserveAspectRatio="xMidYMid meet">
          <path d="M86,54 C120,36 168,40 196,58 C232,52 264,82 262,120 C266,160 240,196 198,202 C158,214 116,212 92,192 C60,200 34,176 42,140 C36,108 58,74 86,54 Z"
                fill="var(--paper-deep)" stroke="rgba(26,23,20,.16)" stroke-width="1" />
          {projets.slice(0, PINS.length).map((_, i) => (
            <g>
              <circle cx={PINS[i][0]} cy={PINS[i][1]} r="7" fill="var(--ink)" />
              <text x={PINS[i][0]} y={PINS[i][1] + 3} text-anchor="middle" font-family="'IBM Plex Mono',monospace" font-size="8" font-weight="600" fill="var(--paper)">{i + 1}</text>
            </g>
          ))}
        </svg>
      </div>
    </div>

    {projets.length > 0 ? (
      <div class="proj-grid">
        {projets.map((p, i) => (
          <a class="pcard plain" href={L(`/projets/${p.id}`)} data-cat={cat(p)}>
            <Axono i={i} teinte={teinteFor(p.id)} class="pcard-axo" />
            <h2 class="pcard-titre">{p.data.titre}</h2>
          </a>
        ))}
      </div>
    ) : (
      <p class="lede">{t('projets.empty')}</p>
    )}
  </section>
</Base>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('.chip-link');
  const cards = document.querySelectorAll<HTMLElement>('.pcard');
  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      const f = chip.dataset.filter;
      chips.forEach((c) => c.setAttribute('aria-pressed', String(c === chip)));
      cards.forEach((card) => {
        card.style.display = f === 'tous' || card.dataset.cat === f ? '' : 'none';
      });
    });
  });
</script>

<style>
  .proj-head {
    display: flex; justify-content: space-between; align-items: flex-start;
    gap: var(--space-l); margin-bottom: clamp(2.5rem, 6vw, 4rem); flex-wrap: wrap;
  }
  /* Chips — liens texte, l'actif souligné */
  .filters { display: flex; flex-wrap: wrap; gap: 1.4rem; }
  .chip-link {
    font-family: var(--font-body); font-size: 15px; letter-spacing: 0.01em;
    color: var(--stone); padding-bottom: 2px; border-bottom: 1.5px solid transparent;
    transition: color 0.2s var(--ease), border-color 0.2s var(--ease);
  }
  .chip-link:hover { color: var(--ink); }
  .chip-link[aria-pressed='true'] { color: var(--ink); border-color: var(--ink); }
  .sort-row {
    display: flex; gap: 2.2rem; margin-top: 1rem;
    font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.04em; color: var(--stone);
  }
  .sort-row .sort { color: var(--ink-soft); }

  .map-wrap { text-align: right; }
  .map-label {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--stone);
  }
  .map { width: clamp(180px, 18vw, 240px); height: auto; margin-top: 0.5rem; display: block; margin-left: auto; }

  /* Grille — valeurs exactes du design : 3 colonnes, gap 68px / 48px */
  .proj-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 68px 48px;
  }
  .pcard { display: block; text-align: center; }
  .pcard :global(.pcard-axo) { margin-bottom: 1rem; }
  .pcard:hover :global(.axono) { transform: translateY(-5px); }
  .pcard-titre {
    font-family: var(--font-display); font-weight: 500; font-size: 25px; line-height: 1.1;
    color: var(--ink); transition: color 0.2s var(--ease);
  }
  .pcard:hover .pcard-titre { color: var(--terracotta-deep); }

  @media (max-width: 60rem) {
    .proj-grid { grid-template-columns: repeat(2, 1fr); gap: 48px 36px; }
  }
  @media (max-width: 38rem) {
    .proj-grid { grid-template-columns: 1fr; }
    .map-wrap { display: none; }
  }
</style>
